<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.admin.module.business.approval.dao.ApprovalFlowDao">

    <select id="selectByFlowCode" resultType="net.lab1024.sa.admin.module.business.approval.domain.entity.ApprovalFlowEntity">
        SELECT * FROM b_approval_flow
        WHERE flow_code = #{flowCode}
        AND deleted_flag = 0
        LIMIT 1
    </select>

</mapper>
